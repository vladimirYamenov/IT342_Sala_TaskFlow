<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Welcome -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome back!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="4dp"/>

        <!-- Overdue banner -->
        <TextView
            android:id="@+id/tvOverdue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FDECEA"
            android:textColor="#C0392B"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- Stats Grid Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:elevation="2dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📋" android:textSize="24sp"/>
                <TextView android:id="@+id/tvStatTotal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#3B82F6"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total" android:textColor="#64748B" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="12dp"
                android:layout_marginStart="6dp"
                android:elevation="2dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✅" android:textSize="24sp"/>
                <TextView android:id="@+id/tvStatDone"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#22C55E"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Done" android:textColor="#64748B" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Stats Grid Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:elevation="2dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⏳" android:textSize="24sp"/>
                <TextView android:id="@+id/tvStatProgress"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#F59E0B"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="In Progress" android:textColor="#64748B" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="12dp"
                android:layout_marginStart="6dp"
                android:elevation="2dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📌" android:textSize="24sp"/>
                <TextView android:id="@+id/tvStatPending"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#14B8A6"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pending" android:textColor="#64748B" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Recent Tasks -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Recent Tasks"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="#1E293B"/>
                <Button android:id="@+id/btnGoTasks"
                    android:layout_width="wrap_content" android:layout_height="32dp"
                    android:text="View All" android:textSize="12sp"
                    android:backgroundTint="#3B82F6" android:textColor="@android:color/white"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llRecentTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>

        <!-- Groups card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="My Groups"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="#1E293B"/>
                <Button android:id="@+id/btnGoGroups"
                    android:layout_width="wrap_content" android:layout_height="32dp"
                    android:text="View All" android:textSize="12sp"
                    android:backgroundTint="#3B82F6" android:textColor="@android:color/white"/>
            </LinearLayout>

            <TextView android:id="@+id/tvGroupCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 groups" android:textColor="#64748B" android:textSize="14sp"/>
        </LinearLayout>

        <!-- Logout -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log Out"
            android:backgroundTint="#EF4444"
            android:textColor="@android:color/white"/>

    </LinearLayout>
</ScrollView>
