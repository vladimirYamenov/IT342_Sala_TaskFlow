<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:elevation="2dp">

    <!-- Title + action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1E293B"/>

        <Button
            android:id="@+id/btnComplete"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="✓ Done"
            android:textSize="11sp"
            android:backgroundTint="#22C55E"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#EF4444"/>
    </LinearLayout>

    <!-- Status + Priority badges -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/tvTaskStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#DBEAFE"
            android:textColor="#1D4ED8"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="11sp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tvTaskPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FEF3C7"
            android:textColor="#92400E"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="11sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTaskDue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvAssigned"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        android:visibility="gone"/>

</LinearLayout>
